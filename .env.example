# Environment variables for tokens-saver-mcp

# Base URL for the OpenAI-compatible local model API
ZAI_BASE_URL=http://127.0.0.1:1234

# Model name to use
ZAI_MODEL=zai-org/glm-4.7-flash

# API key (not required for local models, set to empty string or any value)
ZAI_API_KEY=

# Request timeout in milliseconds (default: 20000)
GLM_TIMEOUT_MS=20000

# Max retries for network errors / timeouts / 5xx (default: 2)
GLM_MAX_RETRIES=2

# Default sampling temperature (default: 0.2)
GLM_TEMPERATURE=0.2
